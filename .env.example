# Copy to the plugin config dir as `.env`:
#   cp .env.example "$(herdr plugin config-dir nathanflurry.jj-workspace)/.env"
#
# Where new jj workspaces are created. If unset, they land next to the repo as
# a sibling directory named "<repo>.<workspace-name>".
# JJ_WORKSPACE_ROOT="$HOME/jj-workspaces"
